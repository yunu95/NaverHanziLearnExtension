let hanzis = [];

// Load Hanzis from storage
chrome.storage.local.get('hanzis', (data) => {
    hanzis = data.hanzis || [];
});

// Helper function to reliably get the current Hanzi
const getCurrentHanzi = () => {
    const urlParams = new URLSearchParams(window.location.search);
    const query = urlParams.get('query') || urlParams.get('q');
    if (query) return query; // URL Params automatically decode %E5%A4%A9 back to Hanzi
    
    return document.title.split(' ')[0];
};

// Function to navigate to the next Hanzi
const navigateToNextHanzi = () => {
    if (hanzis.length === 0) return alert("Please save some Hanzis in the extension popup first.");
    const currentHanzi = getCurrentHanzi();
    const currentIndex = hanzis.indexOf(currentHanzi);

    if (currentIndex === -1) {
        window.location.href = `https://hanja.dict.naver.com/search?query=${hanzis[0]}`;
    } else if (currentIndex < hanzis.length - 1) {
        window.location.href = `https://hanja.dict.naver.com/search?query=${hanzis[currentIndex + 1]}`;
    } else {
        alert("No more next Hanzi.");
    }
};

// Function to navigate to the previous Hanzi
const navigateToPreviousHanzi = () => {
    if (hanzis.length === 0) return alert("Please save some Hanzis in the extension popup first.");
    const currentHanzi = getCurrentHanzi();
    const currentIndex = hanzis.indexOf(currentHanzi);

    if (currentIndex === -1) {
        window.location.href = `https://hanja.dict.naver.com/search?query=${hanzis[hanzis.length - 1]}`;
    } else if (currentIndex > 0) {
        window.location.href = `https://hanja.dict.naver.com/search?query=${hanzis[currentIndex - 1]}`;
    } else {
        alert("No more previous Hanzi.");
    }
};

// Function to reset and jump to the first Hanzi
const resetHanziIndex = () => {
    if (hanzis.length === 0) return alert("Please save some Hanzis in the extension popup first.");
    window.location.href = `https://hanja.dict.naver.com/search?query=${hanzis[0]}`;
};

// Add event listener for keyboard shortcuts
document.addEventListener('keydown', (event) => {
    if (event.key === 'ArrowRight' && event.ctrlKey) {
        event.preventDefault();
        navigateToNextHanzi();
    }
    if (event.key === 'ArrowLeft' && event.ctrlKey) {
        event.preventDefault();
        navigateToPreviousHanzi();
    }
    if (event.key === 'ArrowDown' && event.ctrlKey) {
        event.preventDefault();
        resetHanziIndex();
    }
});

